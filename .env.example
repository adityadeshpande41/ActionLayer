# Server Configuration
PORT=5001
NODE_ENV=development

# Database
# Development (SQLite)
DATABASE_URL=sqlite.db
# Production (PostgreSQL) - use connection string from Render
# DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_SSL=true

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-super-secret-session-key-change-in-production

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Google Calendar (for production, set as JSON string in environment variable)
# GOOGLE_CREDENTIALS={"web":{"client_id":"...","client_secret":"...","redirect_uris":["https://your-app.onrender.com/api/calendar/google/callback"]}}

# Jira Integration (Optional - configure via UI)
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token
